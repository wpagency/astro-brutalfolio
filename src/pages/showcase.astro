---
import BaseLayout from '../layouts/BaseLayout.astro';
import ProjectShowcase from '../components/ProjectShowcase.astro';
import BrutalCursor from '../components/islands/BrutalCursor';
import ScrollAnimations from '../components/islands/ScrollAnimations';

const pageTitle = 'Project Showcase | BrutalFolio - Featured Work';
const pageDescription = 'Detailed showcase of our featured projects with screenshots and case studies.';

const showcaseProjects = [
  {
    title: 'Team Prep Starz',
    url: 'teamprepstarz.com',
    category: 'FITNESS PLATFORM',
    description: 'Elite fitness training & performance coaching platform. Custom athlete transformations, hockey performance optimization, and body composition programs with proven results.',
    features: [
      'Video-driven hero section with custom controls',
      'Elite training programs for hockey and physique',
      'Modern tech stack with service workers',
      'Athlete transformation gallery',
      'Advanced form handling with local storage backup'
    ],
    stats: {
      athletes: '100+',
      programs: 'Elite',
      results: 'Proven'
    },
    color: 'bg-brutal-red',
    screenshot: 'https://images.unsplash.com/photo-1571902943202-507ec2618e8f?w=1600&h=900&fit=crop'
  },
  {
    title: 'Whole Leaf Tobacco',
    url: 'wholeleaftobacco.com',
    category: 'E-COMMERCE',
    description: 'Complete WordPress + WooCommerce management with specialized tobacco products, custom wiki integration, and regulatory compliance features.',
    features: [
      'WooCommerce specialized product catalog',
      'Custom wiki knowledge base integration',
      'Regulatory compliance features',
      'Monthly SEO optimization',
      'Continuous improvement retainer'
    ],
    stats: {
      products: '500+',
      compliance: '100%',
      growth: '+40%/yr'
    },
    color: 'bg-brutal-green',
    screenshot: 'https://images.unsplash.com/photo-1556742049-0cfed4f6a45d?w=1600&h=900&fit=crop'
  },
  {
    title: 'TotallyYamaha',
    url: 'totallyamaha.com',
    category: 'COMMUNITY FORUM',
    description: 'Yamaha Snowmobile Forums with 10+ years of continuous operation. Built to survive the social media era, still thriving with passionate community engagement.',
    features: [
      '10+ years continuous operation',
      'Survived social media competition',
      'Custom forum optimizations',
      'Mobile-responsive design',
      'Advanced moderation tools'
    ],
    stats: {
      years: '15+',
      members: '50K+',
      posts: '1M+'
    },
    color: 'bg-brutal-yellow',
    screenshot: 'https://images.unsplash.com/photo-1578662996442-48f60103fc31?w=1600&h=900&fit=crop'
  },
  {
    title: 'Roseville Rock Supply',
    url: 'rosevillerocksupply.com',
    category: 'BUSINESS SITE',
    description: 'Transformed from WordPress to Astro. Now running on autopilot with self-maintaining performance metrics, true set-and-forget architecture.',
    features: [
      'WordPress to Astro transformation',
      'Zero maintenance required',
      'Self-maintaining performance',
      'Lightning-fast load times',
      'Set-and-forget architecture'
    ],
    stats: {
      speed: '0.6s',
      maintenance: 'Zero',
      uptime: '100%'
    },
    color: 'bg-brutal-purple',
    screenshot: 'https://images.unsplash.com/photo-1558618666-fcd25c85cd64?w=1600&h=900&fit=crop'
  }
];
---

<BaseLayout title={pageTitle} description={pageDescription}>
  <!-- Custom Cursor -->
  <div class="hidden lg:block">
    <BrutalCursor client:load />
  </div>

  <!-- Scroll Animations -->
  <ScrollAnimations client:load />

  <!-- Grain Overlay -->
  <div class="fixed inset-0 pointer-events-none z-[9996] opacity-[0.03] grain"></div>

  <!-- Hero Section -->
  <section class="relative min-h-[50vh] flex items-center justify-center overflow-hidden bg-brutal-black text-brutal-white pt-32">
    <!-- Animated Shapes -->
    <div class="absolute top-20 left-20 w-64 h-64 bg-brutal-red transform rotate-45 animate-float opacity-20"></div>
    <div class="absolute bottom-20 right-20 w-48 h-48 border-[20px] border-brutal-yellow animate-float animation-delay-400 opacity-20"></div>

    <div class="container mx-auto px-edge relative z-10">
      <div class="max-w-4xl mx-auto text-center">
        <h1 class="font-display font-black text-[clamp(3rem,10vw,8rem)] leading-[0.85] mb-8">
          <span class="block text-brutal-yellow">PROJECT</span>
          <span class="block text-outline -mt-4">SHOWCASE</span>
        </h1>
        <p class="text-2xl md:text-3xl font-display font-bold">
          Featured work with detailed breakdowns
        </p>
      </div>
    </div>
  </section>

  <!-- Showcase Projects -->
  {showcaseProjects.map((project, index) => (
    <section class={`py-section ${index % 2 === 0 ? 'bg-brutal-white' : 'bg-brutal-gray'}`}>
      <div class="container mx-auto px-edge">
        <ProjectShowcase {...project} />
      </div>
    </section>
  ))}

  <!-- CTA Section -->
  <section class="py-section bg-brutal-black text-brutal-white">
    <div class="container mx-auto px-edge text-center">
      <h2 class="font-display font-black text-[clamp(2rem,8vw,5rem)] mb-8">
        READY TO JOIN THE ROSTER?
      </h2>
      <p class="text-2xl font-bold mb-12 max-w-3xl mx-auto">
        These projects run themselves. Zero downtime. Maximum performance. Let's build yours.
      </p>
      <a href="/contact" class="inline-block px-12 py-6 bg-brutal-yellow text-brutal-black font-black text-xl uppercase border-4 border-brutal-yellow shadow-brutal-xl hover:shadow-brutal hover:translate-x-2 hover:translate-y-2 transition-all">
        START YOUR PROJECT →
      </a>
    </div>
  </section>
</BaseLayout>

