---
import { getCollection } from 'astro:content';
import BaseLayout from '../../../layouts/BaseLayout.astro';
import BrutalCursor from '../../../components/islands/BrutalCursor';
import ScrollAnimations from '../../../components/islands/ScrollAnimations';

// Get all published blog posts
const posts = await getCollection('blog', ({ data }) => {
  return data.draft !== true;
});

// Sort posts by date
posts.sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

const pageTitle = 'Blog | BrutalFolio - Insights WordPress sin Tonterías';
const pageDescription = 'Conversación real sobre WordPress, rendimiento y desarrollo web. Sin relleno, solo hechos.';

// Format date function
const formatDate = (date: Date) => {
  return new Intl.DateTimeFormat('es-ES', {
    year: 'numeric',
    month: 'long',
    day: 'numeric'
  }).format(date);
};
---

<BaseLayout title={pageTitle} description={pageDescription} locale="es_ES">
  <!-- Custom Cursor -->
  <div class="hidden lg:block">
    <BrutalCursor client:load />
  </div>

  <!-- Scroll Animations -->
  <ScrollAnimations client:load />

  <!-- Grain Overlay -->
  <div class="fixed inset-0 pointer-events-none z-[9996] opacity-[0.03] grain"></div>

  <!-- Hero Section -->
  <section class="relative min-h-[50vh] flex items-center justify-center overflow-hidden bg-brutal-black text-brutal-white pt-32">
    <!-- Geometric Shapes -->
    <div class="absolute top-20 left-20 w-64 h-64 bg-brutal-yellow transform rotate-12 opacity-30"></div>
    <div class="absolute bottom-20 right-20 w-48 h-48 border-[20px] border-brutal-blue transform -rotate-12 opacity-30"></div>

    <div class="container mx-auto px-edge relative z-10">
      <div class="max-w-4xl mx-auto text-center">
        <h1 class="font-display font-black text-[clamp(3rem,10vw,8rem)] leading-[0.85] mb-8">
          <span class="block text-brutal-yellow">BLOG</span>
          <span class="block text-outline -mt-4">SIN TONTERÍAS</span>
        </h1>
        <p class="text-2xl md:text-3xl font-display font-bold">
          Insights reales sobre WordPress.
          <span class="inline-block px-4 py-2 bg-brutal-yellow text-brutal-black transform rotate-1 shadow-brutal ml-2">Sin relleno</span>
        </p>
      </div>
    </div>
  </section>

  <!-- Featured Post -->
  {posts.filter(post => post.data.featured).slice(0, 1).map((post) => (
    <section class="py-section bg-brutal-yellow">
      <div class="container mx-auto px-edge">
        <div class="max-w-6xl mx-auto">
          <div class="mb-8">
            <span class="inline-block px-6 py-3 bg-brutal-black text-brutal-yellow font-mono font-bold text-sm uppercase">
              ARTÍCULO DESTACADO
            </span>
          </div>

          <article class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
            <!-- Content -->
            <div>
              <div class="flex flex-wrap gap-3 mb-4">
                {post.data.tags.map((tag: string) => (
                  <span class="px-3 py-1 bg-brutal-black text-brutal-yellow font-mono text-xs uppercase">
                    {tag}
                  </span>
                ))}
              </div>

              <h2 class="font-display font-black text-[clamp(2rem,5vw,4rem)] leading-[0.9] mb-6">
                {post.data.title}
              </h2>

              <p class="text-xl mb-6">
                {post.data.description}
              </p>

              <div class="flex items-center gap-6 mb-8">
                <time class="font-mono text-sm">
                  {formatDate(post.data.date)}
                </time>
                <span class="font-mono text-sm">
                  {post.data.readTime} min de lectura
                </span>
              </div>

              <a
                href={`/es/blog/${post.slug}`}
                class="inline-block px-8 py-4 bg-brutal-black text-brutal-yellow font-black text-xl uppercase border-4 border-brutal-black shadow-brutal-xl hover:shadow-brutal hover:translate-x-2 hover:translate-y-2 transition-all"
              >
                LEER ARTÍCULO →
              </a>
            </div>

            <!-- Image -->
            <div class="border-mega border-brutal-black shadow-brutal-xl overflow-hidden">
              {post.data.image && (
                <img
                  src={post.data.image}
                  alt={post.data.imageAlt || post.data.title}
                  class="w-full h-full object-cover"
                  loading="lazy"
                />
              )}
            </div>
          </article>
        </div>
      </div>
    </section>
  ))}

  <!-- All Posts -->
  <section class="py-section bg-brutal-gray">
    <div class="container mx-auto px-edge">
      <div class="mb-12">
        <h2 class="font-display font-black text-[clamp(2rem,6vw,4rem)] mb-4">
          <span class="inline-block px-6 py-3 bg-brutal-blue text-brutal-white transform -rotate-1">
            TODOS LOS ARTÍCULOS
          </span>
        </h2>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 xl:grid-cols-3 gap-8 StaggerAnimation">
        {posts.map((post, index) => (
          <article
            class="CardBrutal"
            style={`animation-delay: ${index * 50}ms`}
          >
            {post.data.image && (
              <div class="h-48 border-b-brutal border-brutal-black overflow-hidden">
                <img
                  src={post.data.image}
                  alt={post.data.imageAlt || post.data.title}
                  class="w-full h-full object-cover hover:scale-105 transition-transform duration-300"
                  loading="lazy"
                />
              </div>
            )}

            <div class="p-6">
              <div class="flex flex-wrap gap-2 mb-3">
                {post.data.tags.slice(0, 2).map((tag: string) => (
                  <span class="px-2 py-1 bg-brutal-black text-brutal-white font-mono text-xs uppercase">
                    {tag}
                  </span>
                ))}
              </div>

              <h3 class="font-display font-bold text-2xl mb-3 line-clamp-2">
                {post.data.title}
              </h3>

              <p class="mb-4 line-clamp-3">
                {post.data.description}
              </p>

              <div class="flex items-center justify-between">
                <time class="font-mono text-xs text-brutal-black/60">
                  {formatDate(post.data.date)}
                </time>
                <a
                  href={`/es/blog/${post.slug}`}
                  class="font-black text-brutal-blue hover:text-brutal-black transition-colors"
                >
                  LEER →
                </a>
              </div>
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- Newsletter CTA -->
  <section class="py-section bg-brutal-black text-brutal-white">
    <div class="container mx-auto px-edge text-center">
      <h2 class="font-display font-black text-[clamp(2rem,8vw,5rem)] mb-8">
        ¿QUIERES MÁS?
      </h2>
      <p class="text-2xl font-bold mb-12 max-w-3xl mx-auto">
        Suscríbete para obtener insights exclusivos sobre WordPress, rendimiento web y brutalismo digital.
      </p>
      <form class="max-w-md mx-auto flex flex-col sm:flex-row gap-4">
        <input
          type="email"
          placeholder="tu@email.com"
          class="flex-1 px-6 py-4 bg-brutal-white text-brutal-black font-mono placeholder-brutal-black/50 border-4 border-brutal-yellow outline-none focus:shadow-brutal-lg transition-all"
          required
        />
        <button
          type="submit"
          class="px-8 py-4 bg-brutal-yellow text-brutal-black font-black text-xl uppercase border-4 border-brutal-yellow shadow-brutal hover:shadow-brutal-lg hover:translate-x-[-4px] hover:translate-y-[-4px] transition-all"
        >
          SUSCRIBIR
        </button>
      </form>
    </div>
  </section>
</BaseLayout>


