---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Button from '../../components/ui/Button.astro';
import BrutalCursor from '../../components/islands/BrutalCursor';
import ScrollAnimations from '../../components/islands/ScrollAnimations';

const pageTitle = 'Nuestros Servicios | BrutalFolio - Soluciones WordPress Premium';
const pageDescription = 'Desarrollo WordPress, comercio electrónico, optimización de rendimiento y servicios de mantenimiento. Sin tonterías, solo resultados.';

const services = [
  {
    title: 'Desarrollo WordPress',
    description: 'Temas y plugins personalizados construidos desde cero. Sin constructores inflados, sin compromisos.',
    features: [
      'Desarrollo de tema personalizado',
      'Desarrollo de plugins',
      'Bloques Gutenberg',
      'WordPress sin cabeza',
      'Integraciones de API',
      'Servicios de migración'
    ],
    price: 'Desde $5,000',
    color: 'bg-brutal-yellow'
  },
  {
    title: 'Soluciones de Comercio Electrónico',
    description: 'Tiendas WooCommerce que convierten. Rápidas, seguras y escalables.',
    features: [
      'Configuración de WooCommerce',
      'Flujos de pago personalizados',
      'Integraciones de pagos',
      'Gestión de inventario',
      'Sistemas de suscripción',
      'Soluciones B2B'
    ],
    price: 'Desde $8,000',
    color: 'bg-brutal-blue'
  },
  {
    title: 'Optimización de Rendimiento',
    description: 'Haz tu sitio ultra rápido. Tiempos de carga subsegundos garantizados.',
    features: [
      'Optimización de Core Web Vitals',
      'Optimización de base de datos',
      'Implementación de CDN',
      'Optimización de imágenes',
      'Estrategias de caché',
      'Minificación de código'
    ],
    price: 'Desde $2,500',
    color: 'bg-brutal-green'
  },
  {
    title: 'Mantenimiento y Soporte',
    description: 'Monitoreo 24/7, actualizaciones y soporte. Duerme tranquilo.',
    features: [
      'Monitoreo 24/7',
      'Actualizaciones de seguridad',
      'Actualizaciones de plugins',
      'Copias de seguridad diarias',
      'Monitoreo de rendimiento',
      'Soporte prioritario'
    ],
    price: 'Desde $500/mes',
    color: 'bg-brutal-purple'
  }
];
---

<BaseLayout title={pageTitle} description={pageDescription} locale="es_ES">
  <!-- Custom Cursor -->
  <div class="hidden lg:block">
    <BrutalCursor client:load />
  </div>

  <!-- Scroll Animations -->
  <ScrollAnimations client:load />

  <!-- Grain Overlay -->
  <div class="fixed inset-0 pointer-events-none z-[9996] opacity-[0.03] grain"></div>

  <!-- Hero Section -->
  <section class="relative min-h-[60vh] flex items-center justify-center overflow-hidden bg-brutal-gray pt-32">
    <!-- Geometric Shapes -->
    <div class="absolute -top-20 -right-20 w-80 h-80 bg-brutal-yellow transform rotate-45"></div>
    <div class="absolute -bottom-32 -left-32 w-96 h-96 border-[20px] border-brutal-blue transform -rotate-12"></div>

    <div class="container mx-auto px-edge relative z-10">
      <div class="max-w-4xl mx-auto text-center">
        <h1 class="font-display font-black text-[clamp(3rem,10vw,8rem)] leading-[0.85] mb-8">
          <span class="block text-outline">SERVICIOS</span>
          <span class="block text-brutal-black -mt-4">QUE ENTREGAN</span>
        </h1>
        <p class="text-2xl md:text-3xl font-display font-bold">
          Sin relleno. Sin excusas. Solo
          <span class="inline-block px-4 py-2 bg-brutal-yellow transform -rotate-1 shadow-brutal">resultados</span>
        </p>
      </div>
    </div>
  </section>

  <!-- Services Grid -->
  <section class="py-section bg-brutal-white">
    <div class="container mx-auto px-edge">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-16">
        {services.map((service, index) => (
          <div
            class={`relative p-12 border-mega border-brutal-black shadow-brutal-xl ${service.color} animate-on-scroll transform ${index % 2 === 0 ? 'rotate-1' : '-rotate-1'} hover:rotate-0 transition-transform`}
          >
            <!-- Big Number -->
            <div class="absolute -top-12 -left-12 text-[180px] font-black text-brutal-black/20 leading-none">
              0{index + 1}
            </div>

            <div class="relative z-10">
              <h2 class="font-display font-black text-4xl mb-4 uppercase">
                {service.title}
              </h2>
              <p class="text-xl font-bold mb-8">
                {service.description}
              </p>

              <!-- Features List -->
              <ul class="space-y-3 mb-8">
                {service.features.map((feature) => (
                  <li class="flex items-start gap-3">
                    <span class="inline-block w-6 h-6 bg-brutal-black mt-1"></span>
                    <span class="text-lg font-bold">{feature}</span>
                  </li>
                ))}
              </ul>

              <!-- Price -->
              <div class="flex items-center justify-between">
                <span class="text-3xl font-black">{service.price}</span>
                <Button variant="primary" href="/es/contact" class="shadow-brutal">
                  COMIENZA →
                </Button>
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA Section -->
  <section class="py-section bg-brutal-black text-brutal-white">
    <div class="container mx-auto px-edge text-center">
      <h2 class="font-display font-black text-[clamp(2rem,8vw,6rem)] mb-8">
        ¿LISTO PARA CONSTRUIR?
      </h2>
      <p class="text-2xl mb-12 max-w-3xl mx-auto">
        Creemos algo extraordinario. Sin formularios largos, sin llamadas de ventas. Solo cuéntanos qué necesitas.
      </p>
      <Button variant="primary" size="large" href="/es/contact" class="bg-brutal-yellow text-brutal-black border-brutal-white">
        INICIA TU PROYECTO →
      </Button>
    </div>
  </section>
</BaseLayout>


