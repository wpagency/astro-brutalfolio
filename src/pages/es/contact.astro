---
import BaseLayout from '../../layouts/BaseLayout.astro';
import BrutalCursor from '../../components/islands/BrutalCursor';
import ScrollAnimations from '../../components/islands/ScrollAnimations';

const pageTitle = 'Contacto | BrutalFolio - Vamos a Construir Algo Brutal';
const pageDescription = '¿Listo para construir un sitio de WordPress que se niega a pasar desapercibido? Hablemos sobre tu proyecto.';

const contactMethods = [
  {
    icon: '📧',
    label: 'CORREO',
    value: 'hello@example.com',
    link: 'mailto:hello@example.com',
    color: 'bg-brutal-yellow'
  },
  {
    icon: '💬',
    label: 'DISCORD',
    value: '@brutalfolio',
    link: '#',
    color: 'bg-brutal-blue'
  },
  {
    icon: '🐦',
    label: 'TWITTER',
    value: '@brutalfolio',
    link: 'https://twitter.com/brutalfolioxyz',
    color: 'bg-brutal-green'
  },
  {
    icon: '📱',
    label: 'TELEGRAM',
    value: '@brutalfolio',
    link: '#',
    color: 'bg-brutal-purple'
  }
];

const services = [
  'Desarrollo WordPress',
  'Soluciones de Comercio Electrónico',
  'Optimización de Rendimiento',
  'Plataformas de Foro',
  'Migraciones de Sitios',
  'Mantenimiento y Soporte'
];

const faqs = [
  {
    q: '¿Qué tan rápido puedes construir mi sitio?',
    a: 'No hacemos trabajos apresurados. La calidad requiere un mínimo de 4-8 semanas. Los sitios que duran décadas no se construyen de la noche a la mañana.'
  },
  {
    q: '¿Trabajas con constructores de páginas?',
    a: 'No. Codificamos todo personalizado. Los constructores de páginas son para aficionados.'
  },
  {
    q: '¿Cuál es tu tarifa por hora?',
    a: 'No facturamos por hora. Los proyectos comienzan en $5,000. Estás pagando por resultados, no por tiempo.'
  },
  {
    q: '¿Puedes arreglar mi sitio de WordPress lento?',
    a: 'Sí. Regularmente convertimos desastres de 8 segundos en experiencias subsegundas.'
  },
  {
    q: '¿Proporcionas alojamiento?',
    a: 'Nos asociamos con proveedores empresariales. Nada de basura de alojamiento compartido.'
  },
  {
    q: '¿Qué hay sobre el mantenimiento?',
    a: 'El retén opcional comienza a $500/mes. Incluye actualizaciones, monitoreo y optimización.'
  }
];
---

<BaseLayout title={pageTitle} description={pageDescription} locale="es_ES">
  <!-- Custom Cursor -->
  <div class="hidden lg:block">
    <BrutalCursor client:load />
  </div>

  <!-- Scroll Animations -->
  <ScrollAnimations client:load />

  <!-- Grain Overlay -->
  <div class="fixed inset-0 pointer-events-none z-[9996] opacity-[0.03] grain"></div>

  <!-- Hero Section -->
  <section class="relative min-h-[50vh] flex items-center justify-center overflow-hidden bg-brutal-black text-brutal-white pt-32">
    <!-- Animated Shapes -->
    <div class="absolute top-20 right-20 w-64 h-64 bg-brutal-red transform rotate-45 animate-float opacity-20"></div>
    <div class="absolute bottom-20 left-20 w-48 h-48 border-[20px] border-brutal-yellow transform -rotate-12 animate-float animation-delay-400 opacity-20"></div>

    <div class="container mx-auto px-edge relative z-10">
      <div class="max-w-4xl mx-auto text-center">
        <h1 class="font-display font-black text-[clamp(3rem,10vw,8rem)] leading-[0.85] mb-8">
          <span class="block text-brutal-yellow">VAMOS A</span>
          <span class="block text-outline -mt-4">HABLAR</span>
        </h1>
        <p class="text-2xl md:text-3xl font-display font-bold">
          ¿Tienes un proyecto que necesita
          <span class="inline-block px-4 py-2 bg-brutal-red text-brutal-white transform rotate-1 shadow-brutal ml-2">honestidad brutal?</span>
        </p>
      </div>
    </div>
  </section>

  <!-- Contact Form Section -->
  <section class="py-section bg-brutal-gray">
    <div class="container mx-auto px-edge">
      <div class="max-w-6xl mx-auto">
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-12">
          <!-- Contact Form -->
          <div class="order-2 lg:order-1">
            <div class="border-mega border-brutal-black bg-brutal-white shadow-brutal-xl p-8">
              <h2 class="font-display font-black text-3xl mb-6">
                <span class="inline-block px-4 py-2 bg-brutal-black text-brutal-white">
                  CONSULTA DE PROYECTO
                </span>
              </h2>

              <form class="space-y-6">
                <!-- Name -->
                <div>
                  <label class="block font-mono text-sm uppercase mb-2" for="name">
                    Tu Nombre <span class="text-brutal-red">*</span>
                  </label>
                  <input
                    type="text"
                    id="name"
                    name="name"
                    required
                    class="w-full px-4 py-3 border-brutal border-brutal-black font-mono shadow-brutal focus:shadow-brutal-lg transition-all outline-none"
                    placeholder="Juan García"
                  />
                </div>

                <!-- Email -->
                <div>
                  <label class="block font-mono text-sm uppercase mb-2" for="email">
                    Dirección de Correo <span class="text-brutal-red">*</span>
                  </label>
                  <input
                    type="email"
                    id="email"
                    name="email"
                    required
                    class="w-full px-4 py-3 border-brutal border-brutal-black font-mono shadow-brutal focus:shadow-brutal-lg transition-all outline-none"
                    placeholder="juan@empresa.com"
                  />
                </div>

                <!-- Company -->
                <div>
                  <label class="block font-mono text-sm uppercase mb-2" for="company">
                    Empresa/Organización
                  </label>
                  <input
                    type="text"
                    id="company"
                    name="company"
                    class="w-full px-4 py-3 border-brutal border-brutal-black font-mono shadow-brutal focus:shadow-brutal-lg transition-all outline-none"
                    placeholder="Empresa Increíble"
                  />
                </div>

                <!-- Service Type -->
                <div>
                  <label class="block font-mono text-sm uppercase mb-2" for="service">
                    ¿Qué Necesitas? <span class="text-brutal-red">*</span>
                  </label>
                  <select
                    id="service"
                    name="service"
                    required
                    class="w-full px-4 py-3 border-brutal border-brutal-black font-mono shadow-brutal focus:shadow-brutal-lg transition-all outline-none bg-brutal-white"
                  >
                    <option value="">Selecciona un servicio...</option>
                    {services.map(service => (
                      <option value={service}>{service}</option>
                    ))}
                  </select>
                </div>

                <!-- Budget -->
                <div>
                  <label class="block font-mono text-sm uppercase mb-2" for="budget">
                    Presupuesto del Proyecto <span class="text-brutal-red">*</span>
                  </label>
                  <select
                    id="budget"
                    name="budget"
                    required
                    class="w-full px-4 py-3 border-brutal border-brutal-black font-mono shadow-brutal focus:shadow-brutal-lg transition-all outline-none bg-brutal-white"
                  >
                    <option value="">Selecciona rango de presupuesto...</option>
                    <option value="5-10k">$5,000 - $10,000</option>
                    <option value="10-25k">$10,000 - $25,000</option>
                    <option value="25-50k">$25,000 - $50,000</option>
                    <option value="50k+">$50,000+</option>
                  </select>
                </div>

                <!-- Message -->
                <div>
                  <label class="block font-mono text-sm uppercase mb-2" for="message">
                    Detalles del Proyecto <span class="text-brutal-red">*</span>
                  </label>
                  <textarea
                    id="message"
                    name="message"
                    required
                    rows="6"
                    class="w-full px-4 py-3 border-brutal border-brutal-black font-mono shadow-brutal focus:shadow-brutal-lg transition-all outline-none resize-none"
                    placeholder="Cuéntanos sobre tu proyecto. Sé específico. Apreciamos la franqueza."
                  ></textarea>
                </div>

                <!-- Submit -->
                <button
                  type="submit"
                  class="w-full px-8 py-4 bg-brutal-black text-brutal-white font-black text-xl uppercase border-brutal border-brutal-black shadow-brutal-xl hover:shadow-brutal hover:translate-x-2 hover:translate-y-2 transition-all"
                >
                  ENVIAR CONSULTA DE PROYECTO →
                </button>

                <p class="text-sm text-brutal-black/60 font-mono">
                  * Respondemos dentro de 24 horas. Sin tonterías automatizadas.
                </p>
              </form>
            </div>
          </div>

          <!-- Contact Info -->
          <div class="order-1 lg:order-2 space-y-8">
            <!-- Direct Contact -->
            <div>
              <h3 class="font-display font-black text-2xl mb-6">
                CONTACTO DIRECTO
              </h3>
              <div class="space-y-4">
                {contactMethods.map(method => (
                  <a
                    href={method.link}
                    class={`group flex items-center gap-4 p-4 border-brutal border-brutal-black ${method.color} shadow-brutal hover:shadow-brutal-lg hover:translate-x-[-4px] hover:translate-y-[-4px] transition-all`}
                  >
                    <span class="text-3xl">{method.icon}</span>
                    <div>
                      <div class="font-mono text-xs uppercase">{method.label}</div>
                      <div class="font-display font-bold text-lg">{method.value}</div>
                    </div>
                    <span class="ml-auto text-2xl group-hover:translate-x-2 transition-transform">→</span>
                  </a>
                ))}
              </div>
            </div>

            <!-- Office Hours -->
            <div class="p-6 border-mega border-brutal-black bg-brutal-white shadow-brutal-xl">
              <h3 class="font-display font-black text-2xl mb-4">DISPONIBILIDAD</h3>
              <div class="space-y-2 font-mono">
                <div class="flex justify-between">
                  <span>LUN - VIE</span>
                  <span class="font-bold">9AM - 6PM PST</span>
                </div>
                <div class="flex justify-between">
                  <span>FINES DE SEMANA</span>
                  <span class="font-bold">SOLO EMERGENCIAS</span>
                </div>
                <div class="flex justify-between">
                  <span>TIEMPO DE RESPUESTA</span>
                  <span class="font-bold">&lt; 24 HORAS</span>
                </div>
              </div>
            </div>

            <!-- Quick Stats -->
            <div class="p-6 bg-brutal-yellow border-brutal border-brutal-black shadow-brutal-xl">
              <h3 class="font-display font-black text-2xl mb-4">DATOS RÁPIDOS</h3>
              <ul class="space-y-2 font-bold">
                <li>✓ Proyecto mínimo: $5,000</li>
                <li>✓ Línea de tiempo promedio: 4-8 semanas</li>
                <li>✓ Pago: 50% por adelantado</li>
                <li>✓ Soporte disponible 24/7</li>
                <li>✓ Sin constructores de páginas, nunca</li>
              </ul>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- FAQs Section -->
  <section class="py-section bg-brutal-white">
    <div class="container mx-auto px-edge">
      <div class="max-w-4xl mx-auto">
        <h2 class="font-display font-black text-[clamp(2rem,6vw,4rem)] mb-12 text-center">
          <span class="inline-block px-6 py-3 bg-brutal-blue text-brutal-white transform -rotate-1 shadow-brutal-xl">
            PREGUNTAS FRECUENTES
          </span>
        </h2>

        <div class="space-y-6">
          {faqs.map((faq, index) => (
            <div
              class={`border-brutal border-brutal-black shadow-brutal-lg p-6 bg-brutal-gray animate-on-scroll hover:shadow-brutal-xl hover:translate-x-[-4px] hover:translate-y-[-4px] transition-all`}
              style={`animation-delay: ${index * 50}ms`}
            >
              <h3 class="font-display font-black text-xl mb-3">{faq.q}</h3>
              <p class="text-lg">{faq.a}</p>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- CTA Section -->
  <section class="py-section bg-brutal-black text-brutal-white">
    <div class="container mx-auto px-edge text-center">
      <h2 class="font-display font-black text-[clamp(2rem,8vw,5rem)] mb-8">
        ¿TODAVÍA PENSANDO?
      </h2>
      <p class="text-2xl font-bold mb-12 max-w-3xl mx-auto">
        Tu competencia no lo es. Ya están construyendo. Cada día que esperes es tráfico perdido.
      </p>
      <div class="flex flex-wrap gap-6 justify-center">
        <a href="/es/portfolio" class="inline-block px-12 py-6 bg-brutal-yellow text-brutal-black font-black text-xl uppercase border-4 border-brutal-yellow shadow-brutal-xl hover:shadow-brutal hover:translate-x-2 hover:translate-y-2 transition-all">
          VER NUESTRO TRABAJO →
        </a>
        <a href="/es/services" class="inline-block px-12 py-6 bg-brutal-black text-brutal-white font-black text-xl uppercase border-4 border-brutal-white shadow-brutal-xl hover:bg-brutal-white hover:text-brutal-black hover:shadow-brutal hover:translate-x-2 hover:translate-y-2 transition-all">
          VER SERVICIOS →
        </a>
      </div>
    </div>
  </section>
</BaseLayout>


