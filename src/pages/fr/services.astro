---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Button from '../../components/ui/Button.astro';
import BrutalCursor from '../../components/islands/BrutalCursor';
import ScrollAnimations from '../../components/islands/ScrollAnimations';

const pageTitle = 'Nos Services | BrutalFolio - Solutions WordPress Premium';
const pageDescription = 'Développement WordPress, e-commerce, optimisation des performances et services de maintenance. Pas de bêtises, juste des résultats.';

const services = [
  {
    title: 'Développement WordPress',
    description: 'Thèmes et plugins personnalisés construits à partir de zéro. Pas de constructeurs gonflés, pas de compromis.',
    features: [
      'Développement de thème personnalisé',
      'Développement de plugin',
      'Blocs Gutenberg',
      'WordPress sans tête',
      'Intégrations API',
      'Services de migration'
    ],
    price: 'À partir de 5 000 €',
    color: 'bg-brutal-yellow'
  },
  {
    title: 'Solutions de Commerce Électronique',
    description: 'Les magasins WooCommerce qui se convertissent. Rapides, sécurisés et évolutifs.',
    features: [
      'Configuration WooCommerce',
      'Flux de paiement personnalisés',
      'Intégrations de paiement',
      'Gestion des stocks',
      'Systèmes d\'abonnement',
      'Solutions B2B'
    ],
    price: 'À partir de 8 000 €',
    color: 'bg-brutal-blue'
  },
  {
    title: 'Optimisation des Performances',
    description: 'Rendez votre site ultra-rapide. Temps de chargement sub-seconde garantis.',
    features: [
      'Optimisation des Core Web Vitals',
      'Optimisation de base de données',
      'Mise en œuvre CDN',
      'Optimisation des images',
      'Stratégies de mise en cache',
      'Minification du code'
    ],
    price: 'À partir de 2 500 €',
    color: 'bg-brutal-green'
  },
  {
    title: 'Maintenance et Support',
    description: 'Surveillance 24/7, mises à jour et support. Dormez tranquille.',
    features: [
      'Surveillance 24/7',
      'Mises à jour de sécurité',
      'Mises à jour de plugin',
      'Sauvegardes quotidiennes',
      'Surveillance des performances',
      'Support prioritaire'
    ],
    price: 'À partir de 500 €/mois',
    color: 'bg-brutal-purple'
  }
];
---

<BaseLayout title={pageTitle} description={pageDescription}>
  <!-- Custom Cursor -->
  <div class="hidden lg:block">
    <BrutalCursor client:load />
  </div>

  <!-- Scroll Animations -->
  <ScrollAnimations client:load />

  <!-- Grain Overlay -->
  <div class="fixed inset-0 pointer-events-none z-[9996] opacity-[0.03] grain"></div>

  <!-- Hero Section -->
  <section class="relative min-h-[60vh] flex items-center justify-center overflow-hidden bg-brutal-gray pt-32">
    <!-- Geometric Shapes -->
    <div class="absolute -top-20 -right-20 w-80 h-80 bg-brutal-yellow transform rotate-45"></div>
    <div class="absolute -bottom-32 -left-32 w-96 h-96 border-[20px] border-brutal-blue transform -rotate-12"></div>

    <div class="container mx-auto px-edge relative z-10">
      <div class="max-w-4xl mx-auto text-center">
        <h1 class="font-display font-black text-[clamp(3rem,10vw,8rem)] leading-[0.85] mb-8">
          <span class="block text-outline">SERVICES</span>
          <span class="block text-brutal-black -mt-4">QUI LIVRENT</span>
        </h1>
        <p class="text-2xl md:text-3xl font-display font-bold">
          Pas de remplissage. Pas d'excuses. Juste
          <span class="inline-block px-4 py-2 bg-brutal-yellow transform -rotate-1 shadow-brutal">des résultats</span>
        </p>
      </div>
    </div>
  </section>

  <!-- Services Grid -->
  <section class="py-section bg-brutal-white">
    <div class="container mx-auto px-edge">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-16">
        {services.map((service, index) => (
          <div
            class={`relative p-12 border-mega border-brutal-black shadow-brutal-xl ${service.color} animate-on-scroll transform ${index % 2 === 0 ? 'rotate-1' : '-rotate-1'} hover:rotate-0 transition-transform`}
          >
            <!-- Big Number -->
            <div class="absolute -top-12 -left-12 text-[180px] font-black text-brutal-black/20 leading-none">
              0{index + 1}
            </div>

            <div class="relative z-10">
              <h2 class="font-display font-black text-4xl mb-4 uppercase">
                {service.title}
              </h2>
              <p class="text-xl font-bold mb-8">
                {service.description}
              </p>

              <!-- Features List -->
              <ul class="space-y-3 mb-8">
                {service.features.map((feature) => (
                  <li class="flex items-start gap-3">
                    <span class="inline-block w-6 h-6 bg-brutal-black mt-1"></span>
                    <span class="text-lg font-bold">{feature}</span>
                  </li>
                ))}
              </ul>

              <!-- Price -->
              <div class="flex items-center justify-between">
                <span class="text-3xl font-black">{service.price}</span>
                <Button variant="primary" href="#contact" class="shadow-brutal">
                  COMMENCER →
                </Button>
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA Section -->
  <section class="py-section bg-brutal-black text-brutal-white">
    <div class="container mx-auto px-edge text-center">
      <h2 class="font-display font-black text-[clamp(2rem,8vw,6rem)] mb-8">
        PRÊT À CONSTRUIRE?
      </h2>
      <p class="text-2xl mb-12 max-w-3xl mx-auto">
        Créons quelque chose d'extraordinaire. Pas de longs formulaires, pas d'appels commerciaux. Dites-nous juste ce dont vous avez besoin.
      </p>
      <Button variant="primary" size="large" href="/fr/contact" class="bg-brutal-yellow text-brutal-black border-brutal-white">
        DÉMARRER VOTRE PROJET →
      </Button>
    </div>
  </section>
</BaseLayout>


