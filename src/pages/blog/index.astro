---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import BrutalCursor from '../../components/islands/BrutalCursor';
import ScrollAnimations from '../../components/islands/ScrollAnimations';

// Get all published blog posts
const posts = await getCollection('blog', ({ data }) => {
  return data.draft !== true;
});

// Sort posts by date
posts.sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

const pageTitle = 'Blog | BrutalFolio - No-BS WordPress Insights';
const pageDescription = 'Real talk about WordPress, performance, and web development. No fluff, just facts.';

// Format date function
const formatDate = (date: Date) => {
  return new Intl.DateTimeFormat('en-US', {
    year: 'numeric',
    month: 'short',
    day: 'numeric'
  }).format(date);
};
---

<BaseLayout title={pageTitle} description={pageDescription}>
  <!-- Custom Cursor -->
  <div class="hidden lg:block">
    <BrutalCursor client:load />
  </div>

  <!-- Scroll Animations -->
  <ScrollAnimations client:load />

  <!-- Grain Overlay -->
  <div class="fixed inset-0 pointer-events-none z-[9996] opacity-[0.03] grain"></div>

  <!-- Hero Section -->
  <section class="relative min-h-[50vh] flex items-center justify-center overflow-hidden bg-brutal-black text-brutal-white pt-32">
    <!-- Geometric Shapes -->
    <div class="absolute top-20 left-20 w-64 h-64 bg-brutal-yellow transform rotate-12 opacity-30"></div>
    <div class="absolute bottom-20 right-20 w-48 h-48 border-[20px] border-brutal-blue transform -rotate-12 opacity-30"></div>

    <div class="container mx-auto px-edge relative z-10">
      <div class="max-w-4xl mx-auto text-center">
        <h1 class="font-display font-black text-[clamp(3rem,10vw,8rem)] leading-[0.85] mb-8">
          <span class="block text-brutal-yellow">BLOG</span>
          <span class="block text-outline -mt-4">NO BS</span>
        </h1>
        <p class="text-2xl md:text-3xl font-display font-bold">
          Real insights. Real results.
          <span class="inline-block px-4 py-2 bg-brutal-yellow text-brutal-black transform -rotate-1 shadow-brutal ml-2">Zero fluff</span>
        </p>
      </div>
    </div>
  </section>

  <!-- Blog Grid -->
  <section class="py-section bg-brutal-gray">
    <div class="container mx-auto px-edge">
      <!-- Featured Posts -->
      {posts.filter(post => post.data.featured).length > 0 && (
        <div class="mb-16">
          <h2 class="font-display font-black text-4xl mb-8 uppercase">
            <span class="inline-block px-6 py-3 bg-brutal-yellow border-brutal border-brutal-black shadow-brutal-lg transform -rotate-1">
              Featured
            </span>
          </h2>
          <div class="grid grid-cols-1 lg:grid-cols-2 gap-12">
            {posts.filter(post => post.data.featured).slice(0, 2).map((post, index) => (
              <article
                class={`group relative border-mega border-brutal-black shadow-brutal-xl bg-brutal-white overflow-hidden animate-on-scroll transform ${index % 2 === 0 ? 'rotate-1' : '-rotate-1'} hover:rotate-0 transition-all`}
              >
                <!-- Featured Image or Color Block -->
                <div class="h-48 bg-brutal-yellow relative overflow-hidden">
                  {post.data.image ? (
                    <img
                      src={post.data.image}
                      alt={post.data.imageAlt || post.data.title}
                      class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-500"
                    />
                  ) : (
                    <div class="w-full h-full bg-brutal-yellow"></div>
                  )}
                  <div class="absolute bottom-4 left-4">
                    <span class="inline-block px-4 py-2 bg-brutal-black text-brutal-white font-mono text-sm">
                      {formatDate(post.data.date)}
                    </span>
                  </div>
                </div>

                <!-- Content -->
                <div class="p-8">
                  <h3 class="font-display font-black text-3xl mb-4 group-hover:text-brutal-blue transition-colors">
                    <a href={`/blog/${post.slug}`} class="hover:underline">
                      {post.data.title}
                    </a>
                  </h3>
                  <p class="text-lg mb-6 font-bold">
                    {post.data.description}
                  </p>

                  <!-- Tags -->
                  <div class="flex flex-wrap gap-2 mb-6">
                    {post.data.tags.map((tag) => (
                      <span class="inline-block px-3 py-1 bg-brutal-gray border-2 border-brutal-black font-mono text-sm">
                        #{tag}
                      </span>
                    ))}
                  </div>

                  <!-- Read More -->
                  <a
                    href={`/blog/${post.slug}`}
                    class="inline-block font-display font-black text-lg uppercase group-hover:translate-x-2 transition-transform"
                  >
                    Read More →
                  </a>
                </div>
              </article>
            ))}
          </div>
        </div>
      )}

      <!-- All Posts -->
      <div>
        <h2 class="font-display font-black text-4xl mb-8 uppercase">
          <span class="inline-block px-6 py-3 bg-brutal-blue text-brutal-white border-brutal border-brutal-black shadow-brutal-lg transform rotate-1">
            All Posts
          </span>
        </h2>
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
          {posts.map((post, index) => (
            <article
              class="group border-brutal border-brutal-black shadow-brutal-lg bg-brutal-white overflow-hidden animate-on-scroll hover:shadow-brutal-xl hover:translate-x-[-4px] hover:translate-y-[-4px] transition-all"
              style={`animation-delay: ${index * 50}ms`}
            >
              <!-- Featured Image or Color Bar -->
              {post.data.image ? (
                <div class="h-48 overflow-hidden relative">
                  <img
                    src={post.data.image}
                    alt={post.data.imageAlt || post.data.title}
                    class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-500"
                  />
                  <div class={`absolute bottom-0 left-0 right-0 h-2 ${['bg-brutal-yellow', 'bg-brutal-blue', 'bg-brutal-green', 'bg-brutal-purple', 'bg-brutal-red'][index % 5]}`}></div>
                </div>
              ) : (
                <div class={`h-2 ${['bg-brutal-yellow', 'bg-brutal-blue', 'bg-brutal-green', 'bg-brutal-purple', 'bg-brutal-red'][index % 5]}`}></div>
              )}

              <!-- Content -->
              <div class="p-6">
                <span class="inline-block px-2 py-1 bg-brutal-black text-brutal-white font-mono text-xs mb-3">
                  {formatDate(post.data.date)}
                </span>
                <h3 class="font-display font-bold text-xl mb-3 group-hover:text-brutal-blue transition-colors">
                  <a href={`/blog/${post.slug}`} class="hover:underline">
                    {post.data.title}
                  </a>
                </h3>
                <p class="text-sm mb-4 line-clamp-3">
                  {post.data.description}
                </p>
                <a
                  href={`/blog/${post.slug}`}
                  class="inline-block font-display font-bold text-sm uppercase group-hover:translate-x-2 transition-transform"
                >
                  Read →
                </a>
              </div>
            </article>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- Newsletter CTA -->
  <section class="py-section bg-brutal-yellow">
    <div class="container mx-auto px-edge text-center">
      <h2 class="font-display font-black text-[clamp(2rem,8vw,5rem)] mb-8">
        WANT THE GOOD STUFF?
      </h2>
      <p class="text-2xl font-bold mb-12 max-w-3xl mx-auto">
        Weekly insights. No spam. Just actionable WordPress wisdom delivered straight to your inbox.
      </p>
      <form class="max-w-md mx-auto flex flex-col sm:flex-row gap-4">
        <input
          type="email"
          placeholder="your@email.com"
          class="flex-grow px-6 py-4 border-brutal border-brutal-black font-mono shadow-brutal focus:shadow-brutal-lg transition-all outline-none"
          required
        />
        <button
          type="submit"
          class="px-8 py-4 bg-brutal-black text-brutal-white font-black uppercase border-brutal border-brutal-black shadow-brutal hover:shadow-brutal-lg hover:translate-x-[-4px] hover:translate-y-[-4px] transition-all"
        >
          Subscribe
        </button>
      </form>
    </div>
  </section>
</BaseLayout>

