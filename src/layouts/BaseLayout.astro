---
import { ViewTransitions } from 'astro:transitions';
import Navigation from '../components/layout/Navigation.astro';
import Footer from '../components/layout/Footer.astro';
import ScrollToTop from '../components/islands/ScrollToTop';
import '../styles/global.css';
import '../styles/design-enhancements.css';

export interface Props {
  title: string;
  description: string;
  ogImage?: string;
  author?: string;
  articleType?: 'article' | 'website' | 'blog';
  publishDate?: string;
  modifiedDate?: string;
  tags?: string[];
  locale?: string;
}

const {
  title,
  description,
  ogImage = '/og-image.png',
  author = 'brutalfolio',
  articleType = 'website',
  publishDate,
  modifiedDate,
  tags = [],
  locale = 'en_US'
} = Astro.props;
const canonicalURL = new URL(Astro.url.pathname, Astro.site);

// Schema.org Organization Schema
const organizationSchema = {
  '@context': 'https://schema.org',
  '@type': 'Organization',
  name: 'brutalfolio',
  url: 'https://example.com',
  logo: 'https://example.com/og-image.png',
  description: 'Modern agency website built with Astro',
  sameAs: [
    'https://twitter.com',
    'https://linkedin.com',
    'https://github.com'
  ],
  contact: {
    '@type': 'ContactPoint',
    contactType: 'Customer Service',
    telephone: '+1-XXX-XXX-XXXX',
    email: 'your-email@example.com'
  }
};

// Schema.org Website Schema
const websiteSchema = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  url: 'https://example.com',
  name: 'brutalfolio',
  description: description,
  potentialAction: {
    '@type': 'SearchAction',
    target: {
      '@type': 'EntryPoint',
      urlTemplate: 'https://example.com/search?q={search_term_string}'
    },
    'query-input': 'required name=search_term_string'
  }
};

// Schema.org Article Schema (for blog posts)
const articleSchema = articleType === 'article' ? {
  '@context': 'https://schema.org',
  '@type': 'BlogPosting',
  headline: title,
  description: description,
  image: ogImage,
  author: {
    '@type': 'Person',
    name: author
  },
  datePublished: publishDate,
  dateModified: modifiedDate || publishDate,
  url: canonicalURL.toString(),
  keywords: tags.join(', ')
} : null;
---

<!DOCTYPE html>
<html lang="en" class="scroll-smooth">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="generator" content={Astro.generator} />
  <meta name="description" content={description} />
  <meta name="author" content={author} />
  <meta name="robots" content="index, follow, max-image-preview:large, max-snippet:-1, max-video-preview:-1" />

  <!-- Open Graph -->
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:image" content={ogImage} />
  <meta property="og:url" content={canonicalURL} />
  <meta property="og:type" content={articleType === 'article' ? 'article' : 'website'} />
  <meta property="og:locale" content={locale} />
  <meta property="og:site_name" content="brutalfolio" />

  <!-- Article specific tags -->
  {articleType === 'article' && publishDate && (
    <meta property="article:published_time" content={publishDate} />
  )}
  {articleType === 'article' && modifiedDate && (
    <meta property="article:modified_time" content={modifiedDate} />
  )}
  {articleType === 'article' && author && (
    <meta property="article:author" content={author} />
  )}
  {articleType === 'article' && tags.length > 0 && (
    tags.map((tag) => (
      <meta property="article:tag" content={tag} />
    ))
  )}

  <!-- PWA -->
  <link rel="manifest" href="/manifest.json" />
  <meta name="theme-color" content="#0A0A0A" />
  <meta name="apple-mobile-web-app-capable" content="yes" />
  <meta name="apple-mobile-web-app-status-bar-style" content="black" />
  <meta name="apple-mobile-web-app-title" content="brutalfolio" />
  <link rel="apple-touch-icon" href="/icon-192.png" />

  <!-- Twitter -->
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={title} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:image" content={ogImage} />

  <!-- Canonical URL -->
  <link rel="canonical" href={canonicalURL} />
  <link rel="sitemap" href="/sitemap-index.xml" />

  <!-- Schema.org Structured Data -->
  <script type="application/ld+json" set:html={JSON.stringify(organizationSchema)} />
  <script type="application/ld+json" set:html={JSON.stringify(websiteSchema)} />
  {articleSchema && (
    <script type="application/ld+json" set:html={JSON.stringify(articleSchema)} />
  )}

  <title>{title}</title>
  <ViewTransitions />
</head>
<body class="min-h-screen flex flex-col">
  <Navigation />
  <main class="flex-grow">
    <slot />
  </main>
  <Footer />
  <ScrollToTop client:load />

  <!-- Service Worker Registration -->
  <script>
    if ('serviceWorker' in navigator && import.meta.env.PROD) {
      window.addEventListener('load', () => {
        navigator.serviceWorker.register('/sw.js')
          .catch(err => {
            // Service Worker registration failed silently
          });
      });
    }
  </script>
</body>
</html>


