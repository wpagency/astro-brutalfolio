---
import { languages } from '../i18n/ui';

const currentLang = Astro.currentLocale ?? 'en';
---

<div class="language-picker">
  <button class="current-lang">
    <span>{languages[currentLang as keyof typeof languages]}</span>
    <svg width="12" height="12" viewBox="0 0 12 12" fill="none" xmlns="http://www.w3.org/2000/svg">
      <path d="M2 4L6 8L10 4" stroke="currentColor" stroke-width="2"/>
    </svg>
  </button>
  <div class="dropdown">
    {Object.entries(languages).map(([lang, label]) => {
      if (lang === currentLang) return null;

      // Build the new URL with the language
      const pathName = Astro.url.pathname;
      let newPath = pathName;

      // Remove current language prefix if it exists
      if (currentLang !== 'en' && pathName.startsWith(`/${currentLang}/`)) {
        newPath = pathName.slice(currentLang.length + 1);
      }

      // Add new language prefix if not English
      if (lang !== 'en') {
        newPath = `/${lang}${newPath}`;
      }

      return (
        <a href={newPath} class="dropdown-item">
          {label}
        </a>
      );
    })}
  </div>
</div>

<style>
  .language-picker {
    position: relative;
  }

  .current-lang {
    display: flex;
    align-items: center;
    gap: 8px;
    padding: 8px 16px;
    background: #0A0A0A;
    color: white;
    border: 2px solid white;
    font-weight: bold;
    font-size: 14px;
    text-transform: uppercase;
    cursor: pointer;
    transition: all 0.2s;
  }

  .current-lang:hover {
    background: white;
    color: #0A0A0A;
  }

  .dropdown {
    position: absolute;
    top: 100%;
    right: 0;
    margin-top: 8px;
    background: white;
    border: 4px solid #0A0A0A;
    box-shadow: 8px 8px 0 0 #0A0A0A;
    min-width: 150px;
    opacity: 0;
    visibility: hidden;
    transform: translateY(-10px);
    transition: all 0.2s;
  }

  .language-picker:hover .dropdown,
  .language-picker:focus-within .dropdown {
    opacity: 1;
    visibility: visible;
    transform: translateY(0);
  }

  .dropdown-item {
    display: block;
    padding: 12px 16px;
    color: #0A0A0A;
    font-weight: bold;
    text-decoration: none;
    text-transform: uppercase;
    font-size: 14px;
    transition: all 0.2s;
  }

  .dropdown-item:hover {
    background: #FFD93D;
  }
</style>


