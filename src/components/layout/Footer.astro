---
import { getLangFromUrl, useTranslations } from "../../i18n/utils";

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const currentYear = new Date().getFullYear();

const footerLinks = {
  services: [
    { label: t("footer.wordpressDev"), href: "#" },
    { label: t("footer.ecommerce"), href: "#" },
    { label: t("footer.performance"), href: "#" },
    { label: t("footer.maintenance"), href: "#" },
  ],
  company: [
    { label: t("footer.aboutUs"), href: "#about" },
    { label: t("footer.ourWork"), href: "#portfolio" },
    { label: t("footer.process"), href: "#" },
    { label: t("footer.careers"), href: "#" },
  ],
  resources: [
    { label: t("footer.blog"), href: "#" },
    { label: t("footer.caseStudies"), href: "#" },
    { label: t("footer.documentation"), href: "#" },
    { label: t("footer.support"), href: "#" },
  ],
};
---

<footer
  class="bg-brutal-black text-brutal-white border-t-mega border-brutal-yellow"
>
  <div class="container mx-auto px-edge py-section">
    <!-- Top Section -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-8 mb-12">
      <!-- Brand -->
      <div class="space-y-4">
        <div class="flex items-center gap-2">
          <div
            class="w-12 h-12 bg-brutal-yellow border-brutal border-brutal-white flex items-center justify-center"
          >
            <span class="font-display font-bold text-xl text-brutal-black"
              >BF</span
            >
          </div>
          <span class="font-display font-bold text-xl">BRUTALFOLIO</span>
        </div>
        <p class="text-brutal-gray">
          {t("footer.taglineShort")}
        </p>
        <!-- Social Links -->
        <div class="flex gap-4">
          <a
            href="#"
            class="w-10 h-10 bg-brutal-white text-brutal-black flex items-center justify-center hover:bg-brutal-yellow transition-colors duration-200"
          >
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
              <path
                d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"
              ></path>
            </svg>
          </a>
          <a
            href="#"
            class="w-10 h-10 bg-brutal-white text-brutal-black flex items-center justify-center hover:bg-brutal-yellow transition-colors duration-200"
          >
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
              <path
                d="M23.953 4.57a10 10 0 01-2.825.775 4.958 4.958 0 002.163-2.723c-.951.555-2.005.959-3.127 1.184a4.92 4.92 0 00-8.384 4.482C7.69 8.095 4.067 6.13 1.64 3.162a4.822 4.822 0 00-.666 2.475c0 1.71.87 3.213 2.188 4.096a4.904 4.904 0 01-2.228-.616v.06a4.923 4.923 0 003.946 4.827 4.996 4.996 0 01-2.212.085 4.936 4.936 0 004.604 3.417 9.867 9.867 0 01-6.102 2.105c-.39 0-.779-.023-1.17-.067a13.995 13.995 0 007.557 2.209c9.053 0 13.998-7.496 13.998-13.985 0-.21 0-.42-.015-.63A9.935 9.935 0 0024 4.59z"
              ></path>
            </svg>
          </a>
          <a
            href="#"
            class="w-10 h-10 bg-brutal-white text-brutal-black flex items-center justify-center hover:bg-brutal-yellow transition-colors duration-200"
          >
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
              <path
                d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zM5.838 12a6.162 6.162 0 1112.324 0 6.162 6.162 0 01-12.324 0zM12 16a4 4 0 110-8 4 4 0 010 8zm4.965-10.405a1.44 1.44 0 112.881.001 1.44 1.44 0 01-2.881-.001z"
              ></path>
            </svg>
          </a>
        </div>
      </div>

      <!-- Links -->
      <div>
        <h3 class="font-display font-bold text-lg mb-4 text-brutal-yellow">
          {t("footer.services")}
        </h3>
        <ul class="space-y-2">
          {
            footerLinks.services.map((link) => (
              <li>
                <a
                  href={link.href}
                  class="text-brutal-gray hover:text-brutal-white transition-colors duration-200"
                >
                  {link.label}
                </a>
              </li>
            ))
          }
        </ul>
      </div>

      <div>
        <h3 class="font-display font-bold text-lg mb-4 text-brutal-yellow">
          {t("footer.company")}
        </h3>
        <ul class="space-y-2">
          {
            footerLinks.company.map((link) => (
              <li>
                <a
                  href={link.href}
                  class="text-brutal-gray hover:text-brutal-white transition-colors duration-200"
                >
                  {link.label}
                </a>
              </li>
            ))
          }
        </ul>
      </div>

      <div>
        <h3 class="font-display font-bold text-lg mb-4 text-brutal-yellow">
          {t("footer.resources")}
        </h3>
        <ul class="space-y-2">
          {
            footerLinks.resources.map((link) => (
              <li>
                <a
                  href={link.href}
                  class="text-brutal-gray hover:text-brutal-white transition-colors duration-200"
                >
                  {link.label}
                </a>
              </li>
            ))
          }
        </ul>
      </div>
    </div>

    <!-- Bottom Section -->
    <div class="border-t-brutal border-brutal-gray pt-8">
      <div class="flex flex-col md:flex-row justify-between items-center gap-4">
        <div>
          <p class="text-brutal-gray text-sm">
            © {currentYear} BRUTALFOLIO. {t("footer.copyright")}
          </p>
          <p class="text-brutal-gray text-sm mt-2">
            Built with ♥ by <a href="https://wpagency.xyz" target="_blank" rel="noopener noreferrer" class="text-brutal-yellow hover:text-brutal-white transition-colors duration-200">WP Agency</a> — WordPress and Beyond
          </p>
        </div>
        <div class="flex gap-6 text-sm">
          <a
            href="#"
            class="text-brutal-gray hover:text-brutal-white transition-colors duration-200"
          >
            {t("footer.privacyPolicy")}
          </a>
          <a
            href="#"
            class="text-brutal-gray hover:text-brutal-white transition-colors duration-200"
          >
            {t("footer.termsOfService")}
          </a>
        </div>
      </div>
    </div>
  </div>
</footer>
