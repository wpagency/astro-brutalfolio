---
import LanguagePicker from "../LanguagePicker.astro";
import { getLangFromUrl, useTranslations } from "../../i18n/utils";

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const navItems = [
  { label: t("nav.services"), href: "/services" },
  { label: t("nav.portfolio"), href: "/portfolio" },
  { label: t("nav.showcase"), href: "/showcase" },
  { label: t("nav.blog"), href: "/blog" },
  { label: t("nav.about"), href: "/about" },
  { label: t("nav.contact"), href: "/contact" },
];
---

<header
  class="fixed top-0 left-0 right-0 z-50 bg-brutal-white border-b-brutal border-brutal-black"
>
  <nav class="container mx-auto px-edge py-4">
    <div class="flex items-center justify-between">
      <!-- Logo -->
      <a href="/" class="group flex items-center gap-2">
        <div
          class="w-12 h-12 bg-brutal-yellow border-brutal border-brutal-black shadow-brutal-sm group-hover:shadow-brutal transition-all duration-200 flex items-center justify-center"
        >
          <span class="font-display font-bold text-lg">BF</span>
        </div>
        <span class="font-display font-bold text-xl hidden sm:block"
          >BRUTALFOLIO</span
        >
      </a>

      <!-- Desktop Navigation -->
      <div class="hidden md:flex items-center gap-8">
        {
          navItems.map((item) => (
            <a
              href={item.href}
              class="font-display font-bold text-lg hover:text-brutal-blue relative group"
            >
              {item.label}
              <span class="absolute -bottom-2 left-0 w-0 h-1 bg-brutal-yellow group-hover:w-full" />
            </a>
          ))
        }
        <LanguagePicker />
        <button class="btn-brutal-primary">
          {t("nav.startProject")}
        </button>
      </div>

      <!-- Mobile Menu Button -->
      <button
        id="mobile-menu-btn"
        class="md:hidden w-12 h-12 border-brutal border-brutal-black bg-brutal-yellow flex items-center justify-center hover:shadow-brutal-sm"
        aria-label="Toggle menu"
      >
        <div class="space-y-1">
          <span class="block w-6 h-1 bg-brutal-black"></span>
          <span class="block w-6 h-1 bg-brutal-black"></span>
          <span class="block w-6 h-1 bg-brutal-black"></span>
        </div>
      </button>
    </div>

    <!-- Mobile Navigation -->
    <div
      id="mobile-menu"
      class="md:hidden absolute top-full left-0 right-0 bg-brutal-white border-b-brutal border-brutal-black transform -translate-y-full opacity-0 pointer-events-none transition-all duration-300 max-h-[calc(100vh-80px)] overflow-y-auto"
    >
      <div class="container mx-auto px-edge py-8 space-y-4">
        {
          navItems.map((item) => (
            <a
              href={item.href}
              class="block font-display font-bold text-xl hover:text-brutal-blue"
            >
              {item.label}
            </a>
          ))
        }
        <div class="pt-4 border-t-4 border-brutal-black">
          <LanguagePicker />
        </div>
        <button class="btn-brutal-primary w-full mt-4">
          {t("nav.startProject")}
        </button>
      </div>
    </div>
  </nav>
</header>

<script>
  // Mobile menu toggle
  const menuBtn = document.getElementById("mobile-menu-btn");
  const mobileMenu = document.getElementById("mobile-menu");
  let isOpen = false;

  menuBtn?.addEventListener("click", () => {
    isOpen = !isOpen;
    if (isOpen) {
      mobileMenu?.classList.remove(
        "-translate-y-full",
        "opacity-0",
        "pointer-events-none",
      );
      mobileMenu?.classList.add("translate-y-0", "opacity-100");
    } else {
      mobileMenu?.classList.add(
        "-translate-y-full",
        "opacity-0",
        "pointer-events-none",
      );
      mobileMenu?.classList.remove("translate-y-0", "opacity-100");
    }
  });

  // Close menu on link click
  const menuLinks = mobileMenu?.querySelectorAll("a");
  menuLinks?.forEach((link) => {
    link.addEventListener("click", () => {
      isOpen = false;
      mobileMenu?.classList.add(
        "-translate-y-full",
        "opacity-0",
        "pointer-events-none",
      );
      mobileMenu?.classList.remove("translate-y-0", "opacity-100");
    });
  });
</script>
