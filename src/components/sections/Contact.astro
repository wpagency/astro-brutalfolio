---
import Button from '../ui/Button.astro';
---

<section id="contact" class="py-section bg-brutal-gray">
  <div class="container mx-auto px-edge">
    <div class="max-w-4xl mx-auto">
      <!-- Section Header -->
      <div class="text-center mb-12">
        <span class="inline-block px-4 py-2 bg-brutal-black text-brutal-white font-mono text-sm mb-4">
          GET IN TOUCH
        </span>
        <h2 class="font-display text-title font-bold mb-6">
          Let's Build
          <span class="text-gradient-brutal"> Something Epic</span>
        </h2>
        <p class="text-xl text-brutal-black/80">
          No long forms. No sales BS. Just tell us what you need.
        </p>
      </div>

      <!-- Contact Form -->
      <div class="card-brutal p-8 bg-brutal-white">
        <form
          id="contact-form"
          class="space-y-6"
          action="https://formspree.io/f/YOUR_FORM_ID"
          method="POST"
          novalidate
        >
          <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
            <div>
              <label class="block font-mono text-sm uppercase mb-2" for="name">
                Name
              </label>
              <input
                type="text"
                id="name"
                name="name"
                class="w-full px-4 py-3 border-brutal border-brutal-black focus:shadow-brutal-sm transition-all duration-200 outline-none"
                required
                minlength="2"
              />
              <span class="text-xs text-red-600 hidden" id="name-error">Please enter a valid name (at least 2 characters)</span>
            </div>
            <div>
              <label class="block font-mono text-sm uppercase mb-2" for="email">
                Email
              </label>
              <input
                type="email"
                id="email"
                name="email"
                class="w-full px-4 py-3 border-brutal border-brutal-black focus:shadow-brutal-sm transition-all duration-200 outline-none"
                required
              />
              <span class="text-xs text-red-600 hidden" id="email-error">Please enter a valid email address</span>
            </div>
          </div>

          <div>
            <label class="block font-mono text-sm uppercase mb-2" for="project">
              Project Type
            </label>
            <select
              id="project"
              name="project"
              class="w-full px-4 py-3 border-brutal border-brutal-black focus:shadow-brutal-sm transition-all duration-200 outline-none bg-brutal-white"
              required
            >
              <option value="">Select a project type</option>
              <option value="wordpress">WordPress Development</option>
              <option value="ecommerce">E-Commerce</option>
              <option value="performance">Performance Optimization</option>
              <option value="maintenance">Maintenance & Support</option>
              <option value="other">Other</option>
            </select>
            <span class="text-xs text-red-600 hidden" id="project-error">Please select a project type</span>
          </div>

          <div>
            <label class="block font-mono text-sm uppercase mb-2" for="message">
              Tell Us About Your Project
            </label>
            <textarea
              id="message"
              name="message"
              rows="6"
              class="w-full px-4 py-3 border-brutal border-brutal-black focus:shadow-brutal-sm transition-all duration-200 outline-none resize-none"
              required
              minlength="10"
            ></textarea>
            <span class="text-xs text-red-600 hidden" id="message-error">Please enter at least 10 characters</span>
          </div>

          <div class="flex flex-col sm:flex-row gap-4 items-center justify-between">
            <p class="text-sm text-brutal-black/60">
              We'll respond within 24 hours. Promise.
            </p>
            <Button variant="primary" size="large" type="submit">
              Send Message
              <svg class="inline-block ml-2 w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M14 5l7 7m0 0l-7 7m7-7H3" />
              </svg>
            </Button>
          </div>
          <p class="text-xs text-brutal-black/60 hidden" id="form-status"></p>
        </form>
      </div>

      <!-- Form Validation Script -->
      <script>
        const form = document.getElementById('contact-form');

        if (form) {
          // Validate individual fields
          const validateField = (fieldId, errorId, rules) => {
            const field = document.getElementById(fieldId);
            const errorSpan = document.getElementById(errorId);

            field?.addEventListener('blur', () => {
              let isValid = true;

              if (rules.required && !field.value.trim()) {
                isValid = false;
              }

              if (rules.minlength && field.value.length < rules.minlength) {
                isValid = false;
              }

              if (rules.email && field.value && !/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(field.value)) {
                isValid = false;
              }

              if (!isValid && errorSpan) {
                errorSpan.classList.remove('hidden');
              } else if (errorSpan) {
                errorSpan.classList.add('hidden');
              }
            });
          };

          // Set up validation for each field
          validateField('name', 'name-error', { required: true, minlength: 2 });
          validateField('email', 'email-error', { required: true, email: true });
          validateField('project', 'project-error', { required: true });
          validateField('message', 'message-error', { required: true, minlength: 10 });

          // Form submission with validation
          form.addEventListener('submit', (e) => {
            e.preventDefault();

            const statusMsg = document.getElementById('form-status');

            // Validate all fields before submission
            const name = document.getElementById('name') as HTMLInputElement;
            const email = document.getElementById('email') as HTMLInputElement;
            const project = document.getElementById('project') as HTMLSelectElement;
            const message = document.getElementById('message') as HTMLTextAreaElement;

            let isFormValid = true;

            if (!name.value.trim() || name.value.length < 2) isFormValid = false;
            if (!email.value.trim() || !/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(email.value)) isFormValid = false;
            if (!project.value) isFormValid = false;
            if (!message.value.trim() || message.value.length < 10) isFormValid = false;

            if (!isFormValid) {
              if (statusMsg) {
                statusMsg.textContent = 'Please fix the errors above before submitting.';
                statusMsg.classList.remove('hidden');
              }
              return;
            }

            if (statusMsg) {
              statusMsg.textContent = 'Sending message...';
              statusMsg.classList.remove('hidden');
            }

            // Note: This form requires backend integration with Formspree or similar service
            // Replace YOUR_FORM_ID with your actual Formspree form ID
            // For testing without backend, uncomment the next lines:

            // if (statusMsg) {
            //   statusMsg.textContent = 'Message sent! We will get back to you soon.';
            //   statusMsg.classList.remove('hidden');
            //   form.reset();
            // }

            // Uncomment the line below when backend is configured
            form.submit();
          });
        }
      </script>

      <!-- Quick Contact -->
      <div class="mt-12 grid grid-cols-1 md:grid-cols-3 gap-6">
        <div class="text-center p-6 bg-brutal-white border-brutal border-brutal-black shadow-brutal">
          <div class="text-2xl mb-2">📧</div>
          <div class="font-mono text-sm uppercase mb-1">Email</div>
          <a href="mailto:your-email@example.com" class="font-display font-bold hover:text-brutal-blue transition-colors">
            your-email@example.com
          </a>
        </div>
        <div class="text-center p-6 bg-brutal-white border-brutal border-brutal-black shadow-brutal">
          <div class="text-2xl mb-2">💬</div>
          <div class="font-mono text-sm uppercase mb-1">Discord</div>
          <a href="#" class="font-display font-bold hover:text-brutal-blue transition-colors">
            @brutalfolio
          </a>
        </div>
        <div class="text-center p-6 bg-brutal-white border-brutal border-brutal-black shadow-brutal">
          <div class="text-2xl mb-2">🚀</div>
          <div class="font-mono text-sm uppercase mb-1">Response Time</div>
          <span class="font-display font-bold text-brutal-green">
            &lt; 24 hours
          </span>
        </div>
      </div>
    </div>
  </div>
</section>


