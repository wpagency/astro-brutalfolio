---
import { getLangFromUrl, useTranslations } from '../../i18n/utils';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const projects = [
  {
    title: 'Apex Fitness Studio',
    category: 'FITNESS',
    description: 'Elite training platform',
    url: 'example-fitness.com',
    color: 'bg-brutal-red',
  },
  {
    title: 'Creative Portfolio',
    category: 'PORTFOLIO',
    description: 'Next.js glitch aesthetic',
    url: 'creativeportfolio.com',
    color: 'bg-brutal-purple',
  },
  {
    title: 'Adventure Trail Forums',
    category: 'COMMUNITY',
    description: '10+ years, 50K+ members',
    url: 'example-trails.com',
    color: 'bg-brutal-yellow',
  },
];
---

<section id="portfolio" class="py-section bg-brutal-gray">
  <div class="container mx-auto px-edge">
    <div class="max-w-6xl mx-auto">
      <!-- Section Header -->
      <div class="mb-12">
        <span class="inline-block px-4 py-2 bg-brutal-black text-brutal-white font-mono text-sm mb-4">
          {t('portfolio.ourWork')}
        </span>
        <h2 class="font-display text-title font-bold mb-6">
          {t('portfolio.title')}
          <span class="text-outline"> {t('portfolio.speaksLouder')}</span>
        </h2>
      </div>

      <!-- Projects Grid -->
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
        {projects.map((project) => (
          <a
            href={`https://${project.url}`}
            target="_blank"
            rel="noopener noreferrer"
            class="card-brutal overflow-hidden group cursor-pointer block hover:shadow-brutal-lg hover:translate-x-[-4px] hover:translate-y-[-4px] transition-all"
          >
            <div class={`h-48 ${project.color} border-b-brutal border-brutal-black relative overflow-hidden`}>
              <div class="absolute inset-0 bg-brutal-black/10 group-hover:bg-brutal-black/20 transition-colors duration-300"></div>
              <div class="absolute bottom-4 right-4">
                <span class="inline-block px-3 py-1 bg-brutal-black text-brutal-white font-mono text-xs">
                  LIVE SITE →
                </span>
              </div>
            </div>
            <div class="p-6 bg-brutal-white">
              <span class="inline-block px-2 py-1 bg-brutal-black text-brutal-white font-mono text-xs mb-2">
                {project.category}
              </span>
              <h3 class="font-display font-bold text-xl mb-2 group-hover:text-brutal-blue transition-colors">
                {project.title}
              </h3>
              <p class="text-brutal-black/80 mb-2">
                {project.description}
              </p>
              <p class="font-mono text-sm text-brutal-black/60">
                {project.url}
              </p>
            </div>
          </a>
        ))}
      </div>

      <!-- View All CTA -->
      <div class="text-center mt-12">
        <a href="/portfolio" class="btn-brutal-primary inline-block">
          VIEW ALL PROJECTS →
        </a>
      </div>
    </div>
  </div>
</section>


