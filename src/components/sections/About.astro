---
import { getLangFromUrl, useTranslations } from '../../i18n/utils';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
---

<section id="about" class="py-section bg-brutal-white">
  <div class="container mx-auto px-edge">
    <div class="max-w-6xl mx-auto">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
        <!-- Content -->
        <div>
          <span class="inline-block px-4 py-2 bg-brutal-black text-brutal-white font-mono text-sm mb-4">
            {t('about.aboutUs')}
          </span>
          <h2 class="font-display text-title font-bold mb-6">
            {t('about.15Years')}
            <span class="text-gradient-brutal"> {t('about.noNonsense')}</span>
            <br />{t('about.wpExcellence')}
          </h2>
          <p class="text-xl mb-6">
            {t('about.sinceBefore')}
          </p>
          <p class="text-lg text-brutal-black/80 mb-8">
            {t('about.stillThink')}
          </p>
          <div class="grid grid-cols-2 gap-6">
            <div class="p-4 border-brutal border-brutal-black bg-brutal-yellow">
              <div class="font-display font-bold text-3xl mb-2">500+</div>
              <div class="font-mono text-sm uppercase">{t('about.projectsDelivered')}</div>
            </div>
            <div class="p-4 border-brutal border-brutal-black bg-brutal-blue text-brutal-white">
              <div class="font-display font-bold text-3xl mb-2">100%</div>
              <div class="font-mono text-sm uppercase">{t('about.clientSatisfaction')}</div>
            </div>
          </div>
        </div>

        <!-- Visual Element -->
        <div class="relative">
          <div class="w-full h-96 bg-brutal-gray border-brutal border-brutal-black shadow-brutal-xl relative">
            <div class="absolute -top-4 -left-4 w-32 h-32 bg-brutal-yellow border-brutal border-brutal-black animate-float"></div>
            <div class="absolute -bottom-4 -right-4 w-24 h-24 bg-brutal-blue border-brutal border-brutal-black animate-float animation-delay-400"></div>
            <div class="absolute inset-0 flex items-center justify-center">
              <span class="font-display font-bold text-6xl text-outline">WP</span>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>


