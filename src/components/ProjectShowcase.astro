---
interface Props {
  title: string;
  url: string;
  category: string;
  description: string;
  features: string[];
  stats: { [key: string]: string };
  color: string;
  screenshot?: string;
}

const { title, url, category, description, features, stats, color, screenshot } = Astro.props;
---

<div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
  <!-- Project Info -->
  <div>
    <span class={`inline-block px-4 py-2 ${color} text-brutal-black font-mono font-bold mb-4`}>
      {category}
    </span>
    <h3 class="font-display font-black text-[clamp(2rem,5vw,3.5rem)] mb-6">
      {title}
    </h3>
    <p class="text-xl mb-8 font-bold text-brutal-black/90">
      {description}
    </p>

    <!-- Key Features -->
    {features && features.length > 0 && (
      <div class="space-y-4 mb-8">
        {features.map((feature) => (
          <div class="flex items-start gap-4">
            <span class={`block w-6 h-6 ${color} flex-shrink-0 mt-1`}></span>
            <div class="font-bold">{feature}</div>
          </div>
        ))}
      </div>
    )}

    <!-- Stats -->
    {stats && Object.keys(stats).length > 0 && (
      <div class="grid grid-cols-3 gap-4 mb-8">
        {Object.entries(stats).map(([key, value]) => (
          <div class="p-4 border-brutal border-brutal-black bg-brutal-white">
            <div class="text-2xl font-black">{value}</div>
            <div class="font-mono text-sm uppercase">{key}</div>
          </div>
        ))}
      </div>
    )}

    <a
      href={`https://${url}`}
      target="_blank"
      rel="noopener noreferrer"
      class="inline-block px-8 py-4 bg-brutal-black text-brutal-white font-black text-xl uppercase border-brutal border-brutal-black shadow-brutal-xl hover:shadow-brutal hover:translate-x-2 hover:translate-y-2 transition-all"
    >
      VISIT LIVE SITE →
    </a>
  </div>

  <!-- Screenshot Preview -->
  <div class="relative">
    <div class="border-mega border-brutal-black shadow-brutal-xl bg-brutal-white overflow-hidden transform hover:rotate-0 transition-transform">
      <!-- Browser Chrome -->
      <div class="bg-brutal-gray p-3 border-b-mega border-brutal-black flex items-center gap-2">
        <span class="w-3 h-3 bg-brutal-red border-2 border-brutal-black"></span>
        <span class="w-3 h-3 bg-brutal-yellow border-2 border-brutal-black"></span>
        <span class="w-3 h-3 bg-brutal-green border-2 border-brutal-black"></span>
        <span class="ml-auto font-mono text-sm text-brutal-black font-bold">{url}</span>
      </div>

      <!-- Screenshot Content -->
      <div class="relative aspect-video bg-gradient-to-br from-brutal-gray to-brutal-gray/90 overflow-hidden">
        {screenshot ? (
          <img
            src={screenshot}
            alt={`${title} website screenshot`}
            class="w-full h-full object-cover object-top"
            loading="lazy"
          />
        ) : (
          <div class="absolute inset-0 flex items-center justify-center">
            <div class="text-center">
              <div class="font-display font-black text-3xl mb-2">{title}</div>
              <div class="font-mono text-brutal-black/60">{url}</div>
            </div>
          </div>
        )}

        <!-- Live indicator -->
        <div class="absolute top-4 right-4">
          <span class="inline-flex items-center gap-2 px-3 py-1 bg-brutal-green text-brutal-black font-mono text-xs font-bold">
            <span class="w-2 h-2 bg-brutal-black animate-pulse"></span>
            LIVE
          </span>
        </div>
      </div>
    </div>

    <!-- Decorative elements -->
    <div class={`absolute -bottom-4 -right-4 w-32 h-32 ${color} opacity-30 -z-10`}></div>
    <div class="absolute -top-4 -left-4 w-24 h-24 border-8 border-brutal-black opacity-30 -z-10 rotate-12"></div>
  </div>
</div>


